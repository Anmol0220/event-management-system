APP_NAME=Event Management System
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
SHOW_DOCS=true
SECRET_KEY=change-this-secret-key-before-production-please
CSRF_SECRET_KEY=change-this-csrf-secret-before-production-please
ALLOW_OPEN_ADMIN_SIGNUP=false
ADMIN_SIGNUP_CODE=
SESSION_COOKIE_NAME=ems_session
SESSION_MAX_AGE=28800
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
PRODUCT_IMAGE_MAX_SIZE_BYTES=2097152
LOG_LEVEL=INFO
LOG_SQL_QUERIES=false
UVICORN_WORKERS=1
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=event_management
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
